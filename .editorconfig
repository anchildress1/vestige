root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

[*.{kt,kts}]
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_max-line-length = enabled
ktlint_code_style = intellij_idea
# Compose @Composable + @Preview functions intentionally use PascalCase per the Compose naming convention.
ktlint_function_naming_ignore_when_annotated_with = Composable,Preview

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
