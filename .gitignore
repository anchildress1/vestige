# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/**/build/
!**/src/**/build/

# Android
*.apk
*.aab
*.ap_
*.dex
*.class
bin/
gen/
out/
release/
local.properties
*.iml
captures/
.cxx/
.externalNativeBuild/

# Kotlin / KSP
.kotlin/

# IntelliJ / Android Studio
.idea/*
!.idea/codeStyles/
!.idea/inspectionProfiles/
!.idea/runConfigurations/

# Coverage / reports
**/build/reports/
**/build/test-results/
**/build/jacoco/
**/build/kover/

# OS / editor
.DS_Store
*.swp
*.log
logs/
# Archive raw logcat captures from STT-* harness runs — evidence for ADRs and the blog post.
!docs/stt-results/*.raw.log

# Env / secrets
.env
.env.*
!.env.example
.secrets.baseline.tmp

# Keystore — never check in. See keystore.properties.example for the contract.
keystore.properties
*.jks
*.keystore

# Node — this repo intentionally has no node toolchain. If anything drops these in, ignore.
node_modules/
package-lock.json
bun.lockb

# Models — Gemma 4 .litertlm download lives in app-internal storage at runtime
*.litertlm
*.tflite

# Native libs — extracted at test runtime by Robolectric / ObjectBox; never check these in
libobjectbox-jni-*.dylib
libobjectbox-jni-*.so
libobjectbox-jni-*.dll

# Claude Code session state — session locks, transcripts, scheduled-task metadata
.claude/
