<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Audio capture for voice journaling. The mic is the only sensor we touch. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- One-time, user-initiated model download. Only network event in the app's lifetime. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- The mic is required hardware. -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <application
        android:name=".VestigeApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vestige"
        tools:targetApi="35">

        <!--
            Launcher activities are REQUIRED by Android to set android:exported="true" — the
            system can't locate or start an activity registered for the LAUNCHER intent filter
            otherwise. Semgrep's exported_activity rule treats this as a finding regardless of
            context, so we suppress it here. The activity body must remain a thin Compose entry
            point with no privileged surface (no deeplinks accepting untrusted input, no
            authentication state in extras, no IPC handlers). If that changes, drop the nosem
            and re-evaluate.
        -->
        <!-- nosemgrep: exported_activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Vestige">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
