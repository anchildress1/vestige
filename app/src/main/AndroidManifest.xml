<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Audio capture for voice journaling. The mic is the only sensor we touch. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- One-time, user-initiated model download. Only network event in the app's lifetime. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Conditional foreground service for background extraction (ADR-004). The service promotes
         only while at least one entry's extraction_status is non-terminal; demotes after a 30s
         keep-alive. POST_NOTIFICATIONS is asked at onboarding screen 3.5 in Phase 4. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- The mic is required hardware. -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <application
        android:name=".VestigeApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vestige"
        android:usesCleartextTraffic="false"
        tools:targetApi="35">

        <!-- LiteRT-LM GPU backend needs OpenCL via the vendor namespace. Android 12+ namespace
             isolation hides /vendor/lib*/libOpenCL.so from app linkers unless declared here.
             Both libs are marked optional so devices without GPU OpenCL (or CPU-only runs) still
             load. Per https://ai.google.dev/edge/litert-lm/android. -->
        <uses-native-library
            android:name="libvndksupport.so"
            android:required="false" />
        <uses-native-library
            android:name="libOpenCL.so"
            android:required="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Vestige">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".lifecycle.BackgroundExtractionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
