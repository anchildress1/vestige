    <!-- Screen 1 — Persona pick -->
    <string name="onboarding_persona_header">Pick a persona.</string>
    <string name="onboarding_persona_subhead">Three voices. Same product. Pick the one that fits today. You can switch.</string>
    <string name="onboarding_persona_footer">Change later in settings.</string>
    <string name="onboarding_persona_witness_name">Witness</string>
    <string name="onboarding_persona_witness_desc">Observes. Names the pattern. Keeps quiet otherwise.</string>
    <string name="onboarding_persona_hardass_name">Hardass</string>
    <string name="onboarding_persona_hardass_desc">Sharper. Less padding. More action.</string>
    <string name="onboarding_persona_editor_name">Editor</string>
    <string name="onboarding_persona_editor_desc">Cuts vague words until they confess.</string>

    <!-- Screen 2 — Local processing -->
    <string name="onboarding_local_header">Everything stays on your phone.</string>
    <string name="onboarding_local_body">Vestige runs Gemma 4 directly on this device. No cloud processing, no servers for your entries, no telemetry. Your voice never leaves the device.</string>
    <string name="onboarding_local_detail">The model is ~3.7 GB. We download it once, on Wi-Fi, in the next few steps.</string>

    <!-- Screen 3 — Mic permission -->
    <string name="onboarding_mic_header">Mic permission.</string>
    <string name="onboarding_mic_body">Vestige needs the microphone to record your dumps. Audio is processed by Gemma 4 on this device, then discarded. The transcription stays as text — like any other note.</string>
    <string name="onboarding_mic_allow">Allow microphone</string>
    <string name="onboarding_mic_skip">Skip — I\'ll type instead</string>
    <string name="onboarding_mic_denied">Mic permission required to record. Settings → Permissions.</string>

    <!-- Screen 3.5 — Notification permission -->
    <string name="onboarding_notif_header">One status notification.</string>
    <string name="onboarding_notif_body">Vestige briefly shows a status when it\'s working locally on an entry. That\'s the only notification it will ever send. It disappears when work is done.</string>
    <string name="onboarding_notif_allow">Allow notifications</string>
    <string name="onboarding_notif_skip">Skip — work runs in foreground only</string>
    <string name="onboarding_notif_skip_note">Skipping is fine. Without the notification, Vestige can only finish reading an entry while the app is open — keep it foregrounded until the transcript lands.</string>

    <!-- Screen 4 — Typed fallback -->
    <string name="onboarding_type_header">Or type.</string>
    <string name="onboarding_type_body">Voice is the default. Typing works the same way. Same patterns, same persona. Pick whichever the day is asking for.</string>

