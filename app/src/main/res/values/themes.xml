<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark default. Window chrome paints the canonical Bg token so the system bars blend
         into the Compose canvas instead of stamping `@android:color/black` behind everything. -->
    <style name="Theme.Vestige" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/vestige_bg</item>
        <item name="android:statusBarColor">@color/vestige_bg</item>
        <item name="android:navigationBarColor">@color/vestige_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
</resources>
