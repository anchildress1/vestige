<?xml version="1.0" encoding="utf-8"?>
<!--
    Privacy non-negotiable: no automatic backup, no transfer, nothing leaves the device.
    Export is user-initiated via the Settings screen (PRD §Privacy).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
