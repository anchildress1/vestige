# keystore.properties.example
# Copy this file to keystore.properties (gitignored) and fill in the four fields.
# See docs/architecture-brief.md §"Release Keystore Setup" for keytool instructions.
#
# storeFile  — absolute path to the .jks file (e.g. /Users/<you>/.vestige/keystore.jks)
# keyAlias   — alias used when generating the keypair (e.g. vestige-release)
# storePassword — the keystore password set during keytool -genkeypair
# keyPassword   — the key password (may equal storePassword for a PKCS12 store)

storeFile=/Users/<you>/.vestige/keystore.jks
keyAlias=vestige-release
storePassword=FILL_ME_IN
keyPassword=FILL_ME_IN
