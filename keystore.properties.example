# Vestige release-signing config — copy to `keystore.properties` (gitignored) and fill in.
#
# Per ADR-001 §Q5:
#   1. Generate the keystore once:
#      keytool -genkeypair -v -storetype PKCS12 \
#        -keystore ~/.vestige/keystore.jks \
#        -alias vestige-release -keyalg RSA -keysize 4096 -validity 10000
#   2. Set the four fields below. STORE_PASSWORD and KEY_PASSWORD MUST NOT be committed.
#   3. `./gradlew :app:assembleRelease` then `adb install …` per Story 1.11.
#
# If `keystore.properties` is missing at build time the release variant signs with the
# debug keystore so the pipeline still builds (with a warning) — that is *only* acceptable
# for local agent loops. The submission build (Phase 6) requires the real keystore.

storeFile=/Users/<you>/.vestige/keystore.jks
storePassword=<set in macOS Keychain or .env, never commit>
keyAlias=vestige-release
keyPassword=<set in macOS Keychain or .env, never commit>
